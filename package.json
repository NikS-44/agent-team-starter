{
  "name": "agent-team-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,vite -c blue,magenta \"pnpm run dev:api\" \"vite\"",
    "dev:client": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "lint": "oxlint src db server scripts drizzle.config.ts --config .oxlintrc.json",
    "lint:ts": "tsgolint src",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "dev:ready": "bash scripts/dev-ready.sh",
    "dev:stop": "bash scripts/dev-stop.sh",
    "fallow": "fallow",
    "fallow:audit": "fallow audit",
    "fallow:dead": "fallow dead-code",
    "fallow:health": "fallow health",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "prepare": "husky",
    "precommit": "lint-staged && pnpm run fallow:audit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mts,cts,json,jsonc,css,md}": "biome check --write",
    "*.{ts,tsx,js,jsx,mts,cts}": "oxlint --config .oxlintrc.json --fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/node-server": "^2.0.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "1.168.23",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "hono": "^4.12.14",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.0",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@typescript/native-preview",
      "better-sqlite3",
      "esbuild",
      "msw",
      "oxlint",
      "oxlint-tsgolint"
    ],
    "ignoredBuiltDependencies": ["fallow"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260422.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "fallow": "^2.44.2",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.7.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "msw": {
    "workerDirectory": ["public"]
  }
}
